&lt;&#x2F;span&gt;&lt;span&gt;
&lt;&#x2F;span&gt;&lt;span&gt;        &lt;&#x2F;span&gt;&lt;span style=&quot;color:#bf616a;&quot;&gt;compareDict&lt;&#x2F;span&gt;&lt;span&gt;(previous_map, current_map);
